                  "    const jsonData = pm.response.json();",
                  "    pm.expect(typeof jsonData.id).to.eql(\"number\");",
                  "});",
                  "",
                  "pm.test(\"El 'id' existe y es mayor a 0\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.id).to.exist;",
                  "    pm.expect(jsonData.id).to.be.above(0);",
                  "});",
